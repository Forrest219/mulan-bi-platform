{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(cd frontend && npm:*)",
      "Bash(cd backend && uvicorn:*)",
      "Bash(python3:*)",
      "Bash(sqlite3:*)",
      "Read",
      "Edit(.tsx)",
      "Edit(.ts)",
      "Edit(.py)",
      "Write(.tsx)",
      "Write(.ts)",
      "Write(.py)",
      "Write(.md)",
      "Write(.json)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm:*)"
    ]
  },
  "env": {
    "REACT_APP_API_BASE": "http://localhost:8000"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd frontend && npm run lint 2>&1 | tail -50",
            "timeout": 60,
            "statusMessage": "Running frontend lint..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-handover.sh",
            "timeout": 10,
            "statusMessage": "Checking handover artifacts..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-handover.sh",
            "timeout": 10,
            "statusMessage": "Checking handover artifacts..."
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-handover.sh",
            "timeout": 10,
            "statusMessage": "Checking handover artifacts..."
          }
        ]
      }
    ]
  }
}
