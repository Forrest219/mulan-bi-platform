{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(cd frontend && npm:*)",
      "Bash(cd backend && uvicorn:*)",
      "Bash(python3:*)",
      "Bash(sqlite3:*)",
      "Read",
      "Edit(.tsx)",
      "Edit(.ts)",
      "Edit(.py)",
      "Write(.tsx)",
      "Write(.ts)",
      "Write(.py)",
      "Write(.md)",
      "Write(.json)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm:*)"
    ]
  },
  "env": {
    "REACT_APP_API_BASE": "http://localhost:8000"
  }
}
