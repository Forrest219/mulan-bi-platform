# ──────────────────────────────────────────────
# Mulan BI Platform — 开发环境配置
# 用法: cp config/dev/.env.dev .env
# ──────────────────────────────────────────────

# ── API ──
API_BASE=http://localhost:8000
VITE_PORT=5173

# ── 数据库 ──
DATABASE_URL=postgresql://mulan:mulan@localhost:5432/mulan_bi
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ── 安全密钥（开发环境默认值，生产禁用） ──
SESSION_SECRET=dev-session-secret-do-not-use-in-prod
DATASOURCE_ENCRYPTION_KEY=dev-ds-encryption-key-32bytes!!
TABLEAU_ENCRYPTION_KEY=dev-tab-encryption-key-32bytes!
LLM_ENCRYPTION_KEY=dev-llm-encryption-key-32bytes!

# ── 应用 ──
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3002,http://localhost:3003
SECURE_COOKIES=false
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123

# ── Celery ──
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── 日志 ──
LOG_LEVEL=DEBUG
