# ──────────────────────────────────────────────
# Mulan BI Platform — 生产环境配置模板
# 用法: cp config/prod/.env.prod .env && 修改所有密钥
# ⚠️ 所有密钥必须替换为强随机值！
# ──────────────────────────────────────────────

# ── API ──
API_BASE=https://your-domain.com
# VITE_PORT=5173

# ── 数据库 ──
DATABASE_URL=postgresql://mulan:<STRONG_PASSWORD>@<DB_HOST>:5432/mulan_bi
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ── 安全密钥（必须替换！） ──
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=<REPLACE_WITH_RANDOM_64_HEX>
# 生成: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DATASOURCE_ENCRYPTION_KEY=<REPLACE_WITH_RANDOM_32B>
TABLEAU_ENCRYPTION_KEY=<REPLACE_WITH_RANDOM_32B>
LLM_ENCRYPTION_KEY=<REPLACE_WITH_RANDOM_32B>

# ── 应用 ──
ALLOWED_ORIGINS=https://your-domain.com
SECURE_COOKIES=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<REPLACE_WITH_STRONG_PASSWORD>

# ── Celery ──
CELERY_BROKER_URL=redis://<REDIS_HOST>:6379/0
CELERY_RESULT_BACKEND=redis://<REDIS_HOST>:6379/1

# ── 日志 ──
LOG_LEVEL=WARNING
