    HS --> PG
    LLM --> PG

    AUTH --> REDIS
    LLM --> REDIS

    CELERY --> REDIS
    CELERY --> PG
    CELERY --> TAB
    CELERY --> HS

    TAB --> TABLEAU
    LLM --> OPENAI
    SM --> LLM
    NLQ --> LLM

