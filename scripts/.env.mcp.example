# MCP Servers 环境变量示例
# 复制为 .env.mcp 并填入真实凭证
# 用法: source .env.mcp && ../scripts/start-mcp-servers.sh start
# 或:  export $(cat .env.mcp | xargs) && ../scripts/start-mcp-servers.sh start

# ── Tableau MCP ──────────────────────────────────────────
TABLEAU_MCP_PORT=3927
TABLEAU_SERVER_URL=https://online.tableau.com
TABLEAU_SITE_NAME=zy_bi
TABLEAU_PAT_NAME=mcp_prod_token
TABLEAU_PAT_VALUE=your_pat_value_here

# ── StarRocks MCP ────────────────────────────────────────
STARROCKS_MCP_PORT=8002
STARROCKS_HOST=10.69.65.62
STARROCKS_PORT=8090
STARROCKS_USER=admin
STARROCKS_PASSWORD=your_password_here
STARROCKS_DB=ai

# ── MySQL MCP ────────────────────────────────────────────
MYSQL_MCP_PORT=3000
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=
