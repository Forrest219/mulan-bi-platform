# ── Security keys (MUST replace in production!) ─────────────────────────────
SESSION_SECRET=change-this-to-a-random-secret-in-production
DATASOURCE_ENCRYPTION_KEY=change-this-32bytes-key-exactly!!
TABLEAU_ENCRYPTION_KEY=change-another-32bytes-key-here!!
LLM_ENCRYPTION_KEY=change-llm-32bytes-key-exactly!!!

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://your-server-ip

# ── Cookie security ─────────────────────────────────────────────────────────
SECURE_COOKIES=false

# ── Admin credentials ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-to-strong-password

# ── Tableau MCP Gateway ─────────────────────────────────────────────────────
# GATEWAY_PORT is set to 3928 in docker-compose; GATEWAY_CONFIG_ID selects the DB record
# GATEWAY_CONFIG_ID=1

# ── Note: DATABASE_URL / CELERY_* are injected directly by docker-compose.yml ──
