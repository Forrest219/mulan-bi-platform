# =============================================================================
# Mulan BI Platform - 环境变量示例
# =============================================================================
# 使用方式：复制此文件为 .env，仅修改必填项即可启动服务
# =============================================================================

# ========== 数据库（必填）==========
DATABASE_URL=postgresql://mulan:your-password@localhost:5432/mulan_bi
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ========== 认证（必填）==========
# 会话密钥（生产环境必须使用随机字符串，建议 32+ 字符）
SESSION_SECRET=change-this-to-a-random-secret-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password

# ========== 加密（必填）==========
# 数据源加密密钥（Fernet 需要 32 字节 Base64 编码）
DATASOURCE_ENCRYPTION_KEY=your-fernet-key-here
# Tableau 加密密钥（32 字节）
TABLEAU_ENCRYPTION_KEY=change-this-to-another-key-32b!
# LLM 加密密钥（32 字节，优先使用；若未设置则 fallback 到 DATASOURCE_ENCRYPTION_KEY）
LLM_ENCRYPTION_KEY=change-this-to-llm-key-32bytes!

# ========== Celery / Redis（可选，默认使用本地 Redis）==========
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ========== CORS（可选）==========
# 允许的前端 origins，逗号分隔
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3002,http://localhost:3003
# 生产环境建议设为 true
SECURE_COOKIES=false

# ========== LLM（可选，不配则 AI 功能不可用）==========
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your-api-key
# LLM_MODEL=claude-sonnet-4-6

# ========== Tableau MCP（可选，不配则 Tableau 功能不可用）==========
# Tableau MCP 服务地址（默认：http://localhost:3927/tableau-mcp）
# TABLEAU_MCP_SERVER_URL=http://localhost:3927/tableau-mcp
# TABLEAU_MCP_TIMEOUT=30
# TABLEAU_MCP_PROTOCOL_VERSION=2025-06-18
# Tableau Server 连接信息（可选，提供则使用环境变量方式）
# TABLEAU_SERVER=https://your-tableau-server.com
# TABLEAU_SITE=your-site
# TABLEAU_PAT_NAME=your-pat-name
# TABLEAU_PAT_TOKEN=your-pat-token

# ========== 测试（smoke test 使用）==========
SMOKE_ADMIN_USERNAME=admin
SMOKE_ADMIN_PASSWORD=your-admin-password
