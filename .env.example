# API 配置
API_BASE=http://localhost:8000

# 前端端口（默认5173）
VITE_PORT=5173

# Session 密钥（必填，生产环境请使用强随机字符串）
# 生成方式: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-random-secret-in-production

# 数据源密码加密密钥（必填，正好 32 字节）
# 生成方式: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DATASOURCE_ENCRYPTION_KEY=change-this-to-a-random-key-32b!

# Tableau PAT 加密密钥（必填，正好 32 字节，不得与 DATASOURCE_ENCRYPTION_KEY 相同）
# 生成方式: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TABLEAU_ENCRYPTION_KEY=change-this-to-another-key-32b!

# 允许的 CORS 前端域名（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3002,http://localhost:3003

# 生产环境设置为 true 以启用 Cookie Secure 标志（需 HTTPS）
SECURE_COOKIES=false

# 管理员账户（不配置则不自动创建管理员）
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
